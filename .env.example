DATABASE_URI=mongodb://127.0.0.1/your-database-name
PAYLOAD_SECRET=YOUR_SECRET_HERE
PAYLOAD_API_KEY=your-secure-api-key-here
SERVICE_USER_EMAIL=your-service-user-email-here

# Session expires after this many seconds (default in code: 3600)
PAYLOAD_TOKEN_EXPIRATION_SECONDS=3600

# Optional: best-effort logout when closing the browser tab/window
PAYLOAD_LOGOUT_ON_CLOSE=false